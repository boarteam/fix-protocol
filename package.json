{
  "name": "@boarteam/fix-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Dictionary-driven FIX protocol toolkit for TypeScript: parse, validate, and encode FIX messages.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.7.3",
      "human-id": "4.1.1"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs": "typedoc",
    "crosscheck": "pnpm --filter @boarteam/fix-codegen crosscheck",
    "check:bundle": "node scripts/check-bundle.mjs",
    "examples": "node examples/parse-and-validate.mjs && node examples/encode-a-message.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typedoc": "^0.27.9",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.1.8"
  }
}
